# Bot EV+ v3.0 - Docker Environment
# Copie este arquivo para .env e configure suas variáveis

# ===========================================
# API CONFIGURATION
# ===========================================
ODDS_API_KEY=sua_chave_odds_api_aqui
ODDS_API_BASE=https://api.the-odds-api.com/v4

# ===========================================
# BOT TOKENS (um por feed)
# ===========================================
BOT_TOKEN_DEFAULT=seu_token_bot_default_aqui
BOT_TOKEN_FEED1=seu_token_bot_feed1_aqui
BOT_TOKEN_FEED2=seu_token_bot_feed2_aqui
BOT_TOKEN_FEED3=seu_token_bot_feed3_aqui
BOT_TOKEN_FEED4=seu_token_bot_feed4_aqui
BOT_TOKEN_FEED_AMERICAN=seu_token_bot_americano_aqui

# ===========================================
# SYSTEM CONFIGURATION
# ===========================================
FEED_ID=default
ADMIN_USERS=123456789,987654321
MAX_CONCURRENT_SCANS=3

# ===========================================
# DOCKER SPECIFIC
# ===========================================
# Timezone
TZ=America/Sao_Paulo

# Log level
LOG_LEVEL=INFO

# ===========================================
# OPTIONAL: WEB DASHBOARD
# ===========================================
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0
